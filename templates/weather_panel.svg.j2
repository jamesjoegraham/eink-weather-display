<svg xmlns="http://www.w3.org/2000/svg" width="800" height="480" viewBox="0 0 800 480">

  {% import "metric_card.svg.j2" as components %}
  {% import "hourly_panel.svg.j2" as hourly_panel %}

  <style>
    text { font-family: 'Roboto'; }
  </style>
  <g id="background-layer">
    <rect width="800" height="480" fill="#ffffff"/>
  </g>

  <g id="daynight-bar-group">
    <rect x="0" y="0" width="800" height="6" fill="#e0e0e0"/>
    <rect x="0" y="0" width="{{ daynight_bar_percent }}%" height="6" fill="{{ daynight_bar_color }}"/>
  </g>

  <g id="header-group">
    <text x="776" y="65" font-size="48" font-weight="bold" text-anchor="end" fill="#000000">{{ now_time }}</text>
    <text x="776" y="90" font-size="18" font-weight="bold" text-anchor="end" fill="#00FF00">{{ date }}</text>
  </g>

  <g id="current-conditions-group">
    <rect x="12" y="108" width="776" height="125" rx="12" fill="#ffffff"/>

    <g id="current-summary-group">
      {% set current_icon_x = 31 %}
      {% set current_icon_y = 30 %}
      {% set current_icon_scale = 1.51875 %}
      <g transform="translate({{ current_icon_x }} {{ current_icon_y }}) scale({{ current_icon_scale }})">
        {{ current_icon|safe }}
      </g>
      <text x="240" y="80" font-size="22" font-weight="bold" fill="{{ temp_color }}">CONDITION</text>
      <text x="240" y="110" font-size="30" font-weight="bold" fill="#000000">{{ current_cond }}</text>
      <text x="250" y="183" font-size="78" font-weight="bold" fill="{{ temp_color }}">{{ current_temp }}{{ temp_unit }}</text>
    </g>

    <g id="metrics-panel-group">
      {% for m in metrics %}
      {{ components.metric_card(m, loop.index0) }}
      {% endfor %}
    </g>
  </g>

  <g id="hourly-forecast-group">

    <text x="12" y="270" font-size="18" font-weight="bold" fill="#000000">NEXT 12 HOURS</text>

    {% set start_x = 12 %}
    {% set card_w = 122 %}
    {% set gap = 8 %}
    {% set bar_top = 350 %}
    {% set bar_bottom = 395 %}
    {% for c in connectors %}
      {% set i = c.index %}
      {% set x = start_x + (i + 1) * (card_w + gap) %}
      {% set y1 = bar_top %}
      {% set y2 = bar_bottom %}
      {% if c.kind == 'sunrise' %}
        <rect x="{{ x - 8 }}" y="{{ y1 }}" width="12" height="{{ y2 - y1 }}" rx="4" fill="#ff8000" opacity="1"/>
      {% elif c.kind == 'dusk' %}
        <rect x="{{ x - 8 }}" y="{{ y1 }}" width="12" height="{{ y2 - y1 }}" rx="4" fill="#0000ff" opacity="1"/>
      {% endif %}
    {% endfor %}

    {% for h in hours %}
    {% set card_x = start_x + loop.index0 * (card_w + gap) %}
    {{ hourly_panel.hourly_panel(h, card_x, card_w) }}
    {% endfor %}
  </g>
</svg>
