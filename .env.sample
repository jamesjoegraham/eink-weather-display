# Copy this file to .env and adjust values for your location/display preferences.
# Example:
#   cp .env.example .env

# Open-Meteo location
EINK_WEATHER_LAT=44.6488
EINK_WEATHER_LON=-63.5752
EINK_WEATHER_TZ=America/Halifax

# Number of hourly data points to request (1-12)
EINK_WEATHER_HOURS=6

# Optional: refresh loop interval in seconds.
# Set to 0 (or omit) for one-shot mode.
EINK_WEATHER_REFRESH_SECS=300

# Optional: dashboard theme.
# Supported values: light, dark
EINK_WEATHER_THEME=light

# Optional: preview helpers for desktop/mock iteration.
# If set, the fully rendered template SVG is written here.
# EINK_WEATHER_PREVIEW_SVG_PATH=/tmp/eink-preview.svg

# Forecast source selection.
# live (default) = fetch from Open-Meteo
# demo = built-in static sample set
# mock = configurable synthetic condition generator for UI/icon testing
# EINK_WEATHER_FORECAST_SOURCE=live

# Mock source options (used when EINK_WEATHER_FORECAST_SOURCE=mock)
# EINK_WEATHER_MOCK_PRESET=thunder
# Supported presets:
# clear, partly-cloudy, cloudy, fog, drizzle, rain, showers,
# snow, snow-showers, thunder, hail-thunder
# EINK_WEATHER_MOCK_NIGHT=0
# EINK_WEATHER_MOCK_WEATHER_CODE=95
# EINK_WEATHER_MOCK_PRECIP=85
# EINK_WEATHER_MOCK_TEMP_C=14

# Full preview suite helper:
# scripts/generate_mock_suite.sh
# scripts/generate_mock_suite.sh /tmp/eink-mock-suite

# Optional: if true/1, render data + preview file but skip GPIO/SPI hardware output.
# EINK_WEATHER_PREVIEW_ONLY=false
